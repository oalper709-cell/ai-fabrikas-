# AI Fabrikası — local / staging template
# Copy to apps/api/.env and apps/worker/.env

NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_fabrikasi?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-long-random-secret
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:3000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Storage: local (default) or s3
STORAGE_DRIVER=local
MEDIA_LOCAL_DIR=
MEDIA_PUBLIC_BASE_URL=http://localhost:4000/v1/media

# S3 / R2 / MinIO (when STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=true

RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
