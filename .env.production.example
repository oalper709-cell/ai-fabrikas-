# Copy to .env.production and fill secrets before:
# docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

NODE_ENV=production

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=ai_fabrikasi

API_PORT=4000
WEB_PORT=3000

# Browser-facing origins
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
COOKIE_SECURE=false
ALLOW_LOCAL_PROD=true

# Must be ≥32 random chars
JWT_SECRET=replace-with-at-least-32-char-random-secret!!

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

# local (default volume) | s3
STORAGE_DRIVER=local
MEDIA_PUBLIC_BASE_URL=http://localhost:4000/v1/media

# When STORAGE_DRIVER=s3 (and compose --profile s3)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-fabrikasi
S3_PUBLIC_URL=http://localhost:9000/ai-fabrikasi

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

SENTRY_DSN=
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
